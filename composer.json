{
    "name": "colopl/colopl_timeshifter",
    "description": "Current time modification extension wrapper library.",
    "type": "php-ext",
    "require": {
        "php": "~8.1.0 || ~8.2.0 || ~8.3.0 || ~8.4.1 || ~8.5.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1.32",
        "phpunit/phpunit": "^10 || ^11 || ^12.4.5 || ^13.0.0",
        "phpstan/phpstan-phpunit": "^2.0.8"
    },
    "replace": {
        "ext-colopl_timeshifter": "*"
    },
    "php-ext": {
        "extension-name": "colopl_timeshifter",
        "build-path": "ext",
        "download-url-method": ["pre-packaged-source"],
        "configure-options": [
            {
                "name": "enable-colopl_timeshifter",
                "description": "Whether to enable colopl_timeshifter support"
            }
        ]
    },
    "license": "PHP-3.01",
    "autoload": {
        "psr-4": {
            "Colopl\\ColoplTimeShifter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Colopl\\ColoplTimeShifter\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Go Kudo",
            "email": "g-kudo@colopl.co.jp"
        }
    ],
    "minimum-stability": "stable"
}
